    "migrate:seed": "node src/database/migrate.js && node src/database/seed.js"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "firebase-admin": "^13.7.0",
    "groq-sdk": "^0.3.3",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "redis": "^5.11.0",
