{
  "name": "campusos-backend",
  "version": "1.0.0",
  "description": "CampusOS - AI Powered Smart Campus Management Platform Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "node src/database/migrate.js",
    "migrate:fix": "node migrations/002_schema_fixes.js",
    "migrate:demo": "node migrations/003_demo_seed.js",
    "migrate:all": "node src/database/migrate.js && node migrations/002_schema_fixes.js && node src/database/seed.js && node migrations/003_demo_seed.js",
